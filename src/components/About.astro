---
import type { Locale } from "../data/profile";
import { about, person, languages } from "../data/profile";
import { ui } from "../data/i18n";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const facts = [
  {
    label: ui.labels.location[locale],
    value: person.location[locale],
  },
  {
    label: ui.labels.languages[locale],
    value: languages.map((l) => `${l.name[locale]} (${l.level[locale]})`).join(" · "),
  },
];
---

<section class="section" id="about" aria-labelledby="about-title">
  <div class="container about">
    <div class="about__text">
      <SectionHeading
        eyebrow={ui.sections.about[locale]}
        title={ui.sections.about[locale]}
        id="about-title"
      />
      <div class="about__paragraphs">
        {about.paragraphs[locale].map((p) => <p>{p}</p>)}
      </div>
    </div>

    <aside class="about__facts card" aria-label={ui.sections.about[locale]}>
      <dl>
        {
          facts.map((f) => (
            <div class="about__fact">
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </div>
          ))
        }
      </dl>
    </aside>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
  }

  .about__paragraphs {
    display: grid;
    gap: 1.1rem;
    color: var(--ink-soft);
    font-size: var(--step-1);
    max-width: 62ch;
  }

  .about__facts {
    padding: 1.5rem;
    position: sticky;
    top: 6rem;
  }

  .about__fact + .about__fact {
    margin-top: 1.1rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--border);
  }

  .about__fact dt {
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.3rem;
  }

  .about__fact dd {
    color: var(--ink);
    font-weight: 500;
  }

  @media (max-width: 820px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__facts {
      position: static;
    }
  }
</style>
