---
import type { Locale } from "../data/profile";
import { contact, person } from "../data/profile";
import { ui } from "../data/i18n";
import { withBase } from "../lib/paths";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

// Only render social links that have a real URL configured ("#" = placeholder).
const isPlaceholder = (url: string) => url === "#" || url.trim() === "";

const primary = [
  {
    label: ui.labels.email[locale],
    value: contact.email,
    href: `mailto:${contact.email}`,
    icon: "mail",
  },
  {
    label: ui.labels.phone[locale],
    value: contact.phone,
    href: contact.phoneHref,
    icon: "phone",
  },
  {
    label: ui.labels.location[locale],
    value: person.location[locale],
    href: null,
    icon: "pin",
  },
];

const socials = [
  { label: "LinkedIn", href: contact.linkedin, icon: "linkedin" },
  { label: "GitHub", href: contact.github, icon: "github" },
];
---

<section class="section section--surface" id="contact" aria-labelledby="contact-title">
  <div class="container contact">
    <div class="contact__intro">
      <SectionHeading
        eyebrow={ui.nav.contact[locale]}
        title={ui.sections.contact[locale]}
        lead={ui.sectionLead.contact[locale]}
        id="contact-title"
      />
      <div class="contact__cta">
        <a class="btn btn--primary" href={`mailto:${contact.email}`}>
          {ui.hero.contact[locale]}
        </a>
        <a class="btn btn--ghost" href={withBase(contact.cvUrl)} download>
          {ui.hero.downloadCv[locale]}
        </a>
      </div>
    </div>

    <ul class="contact__list">
      {
        primary.map((item) => (
          <li class="contact__row">
            <span class="contact__icon" aria-hidden="true">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                {item.icon === "mail" && (
                  <>
                    <rect x="3" y="5" width="18" height="14" rx="2" />
                    <path d="M3 7l9 6 9-6" />
                  </>
                )}
                {item.icon === "phone" && (
                  <path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L16 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2" />
                )}
                {item.icon === "pin" && (
                  <>
                    <path d="M12 21s7-5.6 7-11a7 7 0 1 0-14 0c0 5.4 7 11 7 11z" />
                    <circle cx="12" cy="10" r="2.5" />
                  </>
                )}
              </svg>
            </span>
            <span class="contact__meta">
              <span class="contact__label">{item.label}</span>
              {item.href ? (
                <a class="contact__value" href={item.href}>
                  {item.value}
                </a>
              ) : (
                <span class="contact__value">{item.value}</span>
              )}
            </span>
          </li>
        ))
      }

      <li class="contact__socials">
        {
          socials.map((s) =>
            isPlaceholder(s.href) ? (
              <span class="social social--disabled" title="Add your URL in src/data/profile.ts">
                <span class="social__icon" aria-hidden="true">
                  <svg class="icon" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    {s.icon === "linkedin" && (
                      <path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.75V21h-4v-5.3c0-1.26-.02-2.9-1.77-2.9s-2.04 1.38-2.04 2.8V21H9z" />
                    )}
                    {s.icon === "github" && (
                      <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.1-1.47-1.1-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z" />
                    )}
                  </svg>
                </span>
                {s.label}
                <span class="social__hint">{ui.labels.editable[locale]}</span>
              </span>
            ) : (
              <a class="social" href={s.href} target="_blank" rel="me noopener noreferrer">
                <span class="social__icon" aria-hidden="true">
                  <svg class="icon" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    {s.icon === "linkedin" && (
                      <path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.75V21h-4v-5.3c0-1.26-.02-2.9-1.77-2.9s-2.04 1.38-2.04 2.8V21H9z" />
                    )}
                    {s.icon === "github" && (
                      <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.1-1.47-1.1-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z" />
                    )}
                  </svg>
                </span>
                {s.label}
              </a>
            )
          )
        }
      </li>
    </ul>
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(1.75rem, 4vw, 4rem);
    align-items: start;
  }

  .contact__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .contact__list {
    display: grid;
    gap: 0.85rem;
  }

  .contact__row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .contact__icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex: none;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .contact__meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .contact__label {
    font-size: var(--step--1);
    color: var(--muted);
  }

  .contact__value {
    color: var(--ink);
    font-weight: 600;
    word-break: break-word;
  }
  a.contact__value:hover {
    color: var(--accent-strong);
  }

  .contact__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .social {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong);
    background: var(--bg);
    color: var(--ink);
    font-weight: 600;
  }
  .social:hover {
    border-color: var(--accent);
    color: var(--accent-strong);
    text-decoration: none;
  }

  .social__icon .icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .social--disabled {
    color: var(--muted);
    cursor: help;
  }

  .social__hint {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent-strong);
    background: var(--accent-soft);
    padding: 0.12rem 0.4rem;
    border-radius: 999px;
  }

  @media (max-width: 820px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }
</style>
