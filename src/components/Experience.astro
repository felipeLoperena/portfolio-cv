---
import type { Locale } from "../data/profile";
import { experience } from "../data/profile";
import { ui } from "../data/i18n";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="section" id="experience" aria-labelledby="experience-title">
  <div class="container">
    <SectionHeading
      eyebrow={ui.nav.experience[locale]}
      title={ui.sections.experience[locale]}
      id="experience-title"
    />

    <ol class="timeline">
      {
        experience.map((job) => (
          <li class="timeline__item">
            <div class="timeline__marker" aria-hidden="true" />
            <article class="card job">
              <header class="job__head">
                <div>
                  <h3 class="job__role">{job.role[locale]}</h3>
                  <p class="job__company">{job.company}</p>
                </div>
                <p class="job__period">
                  <span>{job.period[locale]}</span>
                  <span class="job__location">{job.location[locale]}</span>
                </p>
              </header>

              <p class="job__summary">{job.summary[locale]}</p>

              <ul class="job__highlights">
                {job.highlights[locale].map((h) => (
                  <li>{h}</li>
                ))}
              </ul>

              <div class="job__tech">
                <span class="visually-hidden">
                  {ui.labels.technologies[locale]}
                </span>
                <ul class="chip-list">
                  {job.tech.map((t) => (
                    <li class="chip">{t}</li>
                  ))}
                </ul>
              </div>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: grid;
    gap: 1.75rem;
    padding-left: 1.75rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.32rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(var(--accent), var(--border));
  }

  .timeline__item {
    position: relative;
  }

  .timeline__marker {
    position: absolute;
    left: calc(-1.75rem + 0.32rem);
    top: 1.6rem;
    transform: translateX(-50%);
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent-soft);
  }

  .job {
    padding: clamp(1.25rem, 1rem + 1vw, 1.9rem);
  }

  .job__head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    align-items: baseline;
    margin-bottom: 0.9rem;
  }

  .job__role {
    font-size: var(--step-2);
  }

  .job__company {
    color: var(--accent-strong);
    font-weight: 600;
    margin-top: 0.15rem;
  }

  .job__period {
    text-align: right;
    color: var(--muted);
    font-size: var(--step--1);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .job__period span:first-child {
    font-weight: 600;
    color: var(--ink-soft);
  }

  .job__summary {
    color: var(--ink-soft);
    margin-bottom: 1rem;
  }

  .job__highlights {
    display: grid;
    gap: 0.6rem;
    margin-bottom: 1.3rem;
  }

  .job__highlights li {
    position: relative;
    padding-left: 1.5rem;
    color: var(--ink-soft);
  }

  .job__highlights li::before {
    content: "";
    position: absolute;
    left: 0.1rem;
    top: 0.65em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 2px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  @media (max-width: 560px) {
    .job__period {
      text-align: left;
    }
  }
</style>
