---
import { Picture } from "astro:assets";
import type { Locale } from "../data/profile";
import { person, contact } from "../data/profile";
import { ui } from "../data/i18n";
import { withBase } from "../lib/paths";
import profilePhoto from "../assets/profile-photo.jpg";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="hero" aria-labelledby="hero-name">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="hero__badge">
        <span class="hero__dot" aria-hidden="true"></span>
        {ui.hero.available[locale]}
      </p>

      <h1 id="hero-name" class="hero__name">{person.name}</h1>
      <p class="hero__headline">
        {person.headline[locale]}
        <span class="hero__tagline">{person.tagline[locale]}</span>
      </p>

      <p class="hero__pitch">{person.pitch[locale]}</p>

      <div class="hero__actions">
        <a class="btn btn--primary" href="#contact">
          {ui.hero.contact[locale]}
        </a>
        <a class="btn btn--ghost btn--on-dark" href="#experience">
          {ui.hero.viewExperience[locale]}
        </a>
        <a
          class="btn btn--ghost btn--on-dark"
          href={withBase(contact.cvUrl)}
          download
        >
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path d="M12 3v12m0 0l-4-4m4 4l4-4"></path>
            <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path>
          </svg>
          {ui.hero.downloadCv[locale]}
        </a>
      </div>
    </div>

    <div class="hero__photo-wrap">
      <div class="hero__photo-glow" aria-hidden="true"></div>
      <Picture
        class="hero__photo"
        src={profilePhoto}
        alt={`Portrait of ${person.name}, ${person.headline[locale]}`}
        widths={[280, 420, 560, 720]}
        sizes="(max-width: 820px) 60vw, 22rem"
        formats={["avif", "webp"]}
        quality={78}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    color: var(--dark-text);
    background:
      radial-gradient(
        60rem 40rem at 15% -10%,
        rgba(47, 100, 240, 0.22),
        transparent 60%
      ),
      radial-gradient(
        50rem 40rem at 100% 0%,
        rgba(99, 102, 241, 0.16),
        transparent 55%
      ),
      linear-gradient(160deg, var(--dark-bg), var(--dark-bg-2));
    overflow: hidden;
  }

  .hero::after {
    /* subtle grid texture, very low contrast */
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(70% 60% at 50% 0%, #000, transparent 80%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    padding-block: clamp(3.5rem, 3rem + 5vw, 7rem);
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--dark-border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--dark-muted);
    font-size: var(--step--1);
    font-weight: 500;
    margin-bottom: 1.4rem;
  }

  .hero__dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.25);
  }

  .hero__name {
    color: #fff;
    font-size: var(--step-4);
    line-height: 1.05;
  }

  .hero__headline {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.9rem;
    margin-top: 0.85rem;
    font-size: var(--step-2);
    font-weight: 600;
    color: var(--dark-text);
  }

  .hero__tagline {
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--dark-muted);
    letter-spacing: 0.01em;
  }

  .hero__pitch {
    margin-top: 1.3rem;
    max-width: 48ch;
    color: var(--dark-muted);
    font-size: var(--step-1);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  /* Photo --------------------------------------------------------------- */
  .hero__photo-wrap {
    position: relative;
    justify-self: center;
    width: min(22rem, 70%);
    aspect-ratio: 4 / 5;
  }

  .hero__photo-glow {
    position: absolute;
    inset: -12%;
    background: radial-gradient(
      closest-side,
      rgba(47, 100, 240, 0.5),
      transparent
    );
    filter: blur(20px);
    z-index: 0;
  }

  .hero__photo {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 30px 60px -25px rgba(0, 0, 0, 0.7);
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: left;
    }

    .hero__photo-wrap {
      order: -1;
      justify-self: start;
      width: min(13rem, 55%);
    }
  }
</style>
