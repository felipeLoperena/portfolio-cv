---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  id?: string;
}
const { eyebrow, title, lead, id } = Astro.props;
---

<div class="section__head">
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="section__title" id={id}>{title}</h2>
  {lead && <p class="section__lead">{lead}</p>}
</div>
